{
  "name": "pro-xslt",
  "version": "0.7.3",
  "description": "Browser-based XSLT processor library (pure JavaScript)",
  "type": "module",
  "main": "dist/pro-xslt.umd.js",
  "module": "dist/pro-xslt.esm.js",
  "browser": "dist/pro-xslt.umd.js",
  "exports": {
    ".": {
      "import": "./dist/pro-xslt.esm.js",
      "require": "./dist/pro-xslt.umd.js",
      "default": "./dist/pro-xslt.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js --watch",
    "bench": "node testing/bench-transform.mjs",
    "bench:compare": "node testing/bench-compare.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "xslt",
    "browser",
    "xml"
  ],
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "jsdom": "^29.0.1",
    "rollup": "^4.28.1",
    "vitest": "^3.0.5"
  }
}
