<!-- XSLT templates -->
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:xlink="http://www.w3.org/1999/xlink">
	<xsl:output method="html" omit-xml-declaration="yes"/>
	<xsl:strip-space elements="*"/>
	<xsl:template match="text()" />
		
<xsl:template name="tree">
	<xsl:for-each select="./*">
		<xsl:call-template name="leaf"/>
	</xsl:for-each>
</xsl:template>

<xsl:template name="leaf">
	<div class="leaf">
		<xsl:if test="@state = 'open'">
			<xsl:attribute name="class">leaf open</xsl:attribute>
		</xsl:if>
		<span>
			<i class="icon-chevron-right"></i>
			<i><xsl:attribute name="class">icon-<xsl:value-of select="@icon" /></xsl:attribute></i>
			<b><xsl:value-of select="@name" /></b>
		</span>
		<div class="children"><xsl:if test="@state = 'open'">
			<xsl:for-each select="./*">
				<xsl:call-template name="leaf"/>
			</xsl:for-each>
		</xsl:if></div>
	</div>
</xsl:template>

</xsl:stylesheet>

