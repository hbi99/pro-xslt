<!-- XSLT templates -->
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:xlink="http://www.w3.org/1999/xlink">
	<xsl:output method="html" omit-xml-declaration="yes"/>
	<xsl:strip-space elements="*"/>
	<xsl:template match="text()" />
		
<xsl:template name="tree">
	<xsl:for-each select="./*">
		<xsl:call-template name="leaf"/>
	</xsl:for-each>
</xsl:template>

<xsl:template name="leaf">
	<div class="leaf">
		<xsl:attribute name="data-id"><xsl:value-of select="@_id" /></xsl:attribute>
		<xsl:if test="@state">
			<xsl:attribute name="class">leaf <xsl:value-of select="@state" /></xsl:attribute>
		</xsl:if>
		<span>
			<xsl:if test="@type">
				<xsl:attribute name="data-type"><xsl:value-of select="@type" /></xsl:attribute>
			</xsl:if>
			<i><xsl:attribute name="class"><xsl:choose>
				<xsl:when test="count(./*) &gt; 0">icon-chevron-right</xsl:when>
				<xsl:otherwise>tree-blank</xsl:otherwise>
			</xsl:choose></xsl:attribute></i>
			<i><xsl:attribute name="class">icon-<xsl:value-of select="@icon" /></xsl:attribute></i>
			<b><xsl:value-of select="@name" /></b>
		</span>
		<div class="children"><xsl:if test="@state = 'open'">
			<xsl:for-each select="./*">
				<xsl:call-template name="leaf"/>
			</xsl:for-each>
		</xsl:if></div>
	</div>
</xsl:template>

</xsl:stylesheet>

