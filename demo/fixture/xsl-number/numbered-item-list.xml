<Scheme>
	<Description><![CDATA[formats item labels with xsl:number]]></Description>
	<XmlData>
		<items>
			<item>Car</item>
			<item>Pen</item>
			<item>LP Record</item>
		</items>
	</XmlData>
	<Template><![CDATA[
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<xsl:template match="/">
		<xsl:for-each select="items/item">
			<xsl:number format="1" />
			<xsl:value-of select="." />
			<br/>
		</xsl:for-each>
	</xsl:template>
</xsl:stylesheet>
]]></Template>
</Scheme>
