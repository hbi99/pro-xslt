<Scheme>
	<Description><![CDATA[should bind `xsl:variable` from content and use in expression]]></Description>
	<XmlData>
		<page>
			<message>x</message>
		</page>
	</XmlData>
	<Template><![CDATA[
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<xsl:template match="/page/message">
		<xsl:variable name="a" select="3" />
		<xsl:value-of select="$a * 4" />
	</xsl:template>
</xsl:stylesheet>
]]></Template>
</Scheme>
