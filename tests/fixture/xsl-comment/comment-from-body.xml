<Scheme>
	<Description><![CDATA[creates a comment from body content]]></Description>
	<XmlData>
		<page><message>Hello</message></page>
	</XmlData>
	<Template><![CDATA[
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<xsl:template match="/page">
		<out>
			<xsl:comment>
				<xsl:text>From </xsl:text>
				<xsl:value-of select="message" />
			</xsl:comment>
		</out>
	</xsl:template>
</xsl:stylesheet>
]]></Template>
</Scheme>
