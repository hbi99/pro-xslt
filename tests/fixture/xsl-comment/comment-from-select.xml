<Scheme>
	<Description><![CDATA[creates a comment from select expression]]></Description>
	<XmlData>
		<page><message>Hello</message></page>
	</XmlData>
	<Template><![CDATA[
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<xsl:template match="/page">
		<out>
			<xsl:comment select="'hello-comment'" />
		</out>
	</xsl:template>
</xsl:stylesheet>
]]></Template>
</Scheme>
