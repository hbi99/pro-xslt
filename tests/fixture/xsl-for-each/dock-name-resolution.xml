<Scheme xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<Description><![CDATA[should render advanced cross reference with current() function]]></Description>
	<ExternalSource href="dock-apps-data.xml"/>
	<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
		<xsl:template match="/">
			<xsl:for-each select="//Settings/dock/*">
				<xsl:sort order="ascending" select="@order" data-type="number"/>
				<xsl:call-template name="dock-temp"/>
			</xsl:for-each>
		</xsl:template>

		<xsl:template name="dock-temp">
			<div>
				<xsl:value-of select="//Settings/Apps/*[@ns=current()/@ns and @id=current()/@id]/@name"/>
			</div>
		</xsl:template>
	</xsl:stylesheet>
</Scheme>
