<Scheme>
	<Description><![CDATA[calls a named template with the current context node]]></Description>
	<XmlData>
		<page>
			<item>Hi</item>
			<item>Bye</item>
		</page>
	</XmlData>
	<Template><![CDATA[
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<xsl:template match="/page/item">
		<xsl:call-template name="emit" />
	</xsl:template>
	<xsl:template name="emit">
		<xsl:value-of select="." />
	</xsl:template>
</xsl:stylesheet>
]]></Template>
</Scheme>
