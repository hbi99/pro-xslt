<Scheme>
	<Description><![CDATA[outputs literal text from the stylesheet]]></Description>
	<XmlData>
		<page><item/></page>
	</XmlData>
	<Template><![CDATA[
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<xsl:template match="/page/item">
		<xsl:text>Hello, </xsl:text>
		<xsl:text>world</xsl:text>
	</xsl:template>
</xsl:stylesheet>
]]></Template>
</Scheme>
