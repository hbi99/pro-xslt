<Scheme>
	<Description><![CDATA[outputs nothing when test is false]]></Description>
	<XmlData>
		<page><item id="2"/></page>
	</XmlData>
	<Template><![CDATA[
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<xsl:template match="/page/item">
		<xsl:if test="@id = '1'">
			<xsl:value-of select="'yes'" />
		</xsl:if>
	</xsl:template>
</xsl:stylesheet>
]]></Template>
</Scheme>
