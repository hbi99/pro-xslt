<Scheme>
	<Description><![CDATA[should output and honor `<xsl:template match="text()"/>`]]></Description>
	<XmlData>
		<page>
			<item>one</item>
			<item>two</item>
		</page>
	</XmlData>
	<Template><![CDATA[
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<xsl:template match="text()"/>
	<xsl:template match="/page/item[1]">
		<xsl:value-of select="." />
	</xsl:template>
</xsl:stylesheet>
]]></Template>
</Scheme>
